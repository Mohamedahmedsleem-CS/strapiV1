{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "banner": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "price": {
      "type": "decimal"
    },
    "instantDelivery": {
      "type": "boolean"
    },
    "files": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "whatsIncluded": {
      "type": "text"
    },
    "isWeighed": {
      "type": "boolean"
    },
    "unit": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::unit.unit"
    },
    "quantity_options": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::quantity-option.quantity-option"
    },
    "originalPrice": {
      "type": "decimal"
    },
    "isBestSeller": {
      "type": "boolean",
      "default": false
    },
    "benefits": {
      "type": "blocks"
    },
    "usageMethods": {
      "type": "blocks"
    },
    "warnings": {
      "type": "blocks"
    },
    "reviewImages": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "offers": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::offer.offer",
      "mappedBy": "products"
    },
    "giftProduct": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::offer.offer",
      "mappedBy": "product"
    }
  }
}
